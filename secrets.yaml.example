# Copy to secrets.yaml and fill in only what you have. Everything here is OPTIONAL;
# without a key the relevant collector degrades to manual entry. No paid API is
# required to run the tracker.

# DeepSeek key for the monthly LLM price scanner (tracker scan-prices). Same key as
# miner_tracker/secrets.yaml; or set the DEEPSEEK_API_KEY env var instead.
# deepseek:
#   api_key: "sk-..."

# Optional FRED API key for the sulfuric-acid PPI collector (free at
# fredgraph — the keyless CSV path also works, so this is optional).
# fred:
#   api_key: ""

# AIS provider for ais_gulf_transits (MarineTraffic / Datalastic / aisstream.io).
# ais_api_key: ""

# Reserved for future paid upgrades (Kpler / Argus / SMM).
# kpler_api_key: ""
# argus_api_key: ""
